{
  "home": {
    "enable": true,
    "host": "home",
    "visibility": "public",
    "root": "/srv/state/public-site",
    "extraConfig": "@resumeAliases path /resume.pdf /Resume.pdf\nredir @resumeAliases /rishabh-goel-resume.pdf 308",
    "description": "Public personal website served through Cloudflare Tunnel"
  },
  "apex": {
    "enable": true,
    "host": "@",
    "visibility": "public",
    "redirectTo": "https://home.therealrishabh.com{uri}",
    "description": "Apex redirect to the public personal website"
  },
  "www": {
    "enable": true,
    "host": "www",
    "visibility": "public",
    "redirectTo": "https://home.therealrishabh.com{uri}",
    "description": "www redirect to the public personal website"
  },
  "example-internal": {
    "enable": false,
    "host": "example",
    "visibility": "internal",
    "response": "Internal route placeholder",
    "description": "Example private tailnet-only route"
  },
  "example-public": {
    "enable": false,
    "host": "example",
    "visibility": "public",
    "response": "Public route placeholder",
    "description": "Example public route"
  }
}
