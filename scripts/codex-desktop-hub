#!/usr/bin/env python3
import html
import json
import os
import re
import select
import shutil
import socket
import subprocess
import sys
import time
from http import HTTPStatus
from http.client import HTTPConnection
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, quote, urlencode, urlsplit


HOST = os.environ.get("CODEX_DESKTOP_HUB_HOST", "127.0.0.1")
PORT = int(os.environ.get("CODEX_DESKTOP_HUB_PORT", "8765"))
STATE_ROOT = Path(os.environ.get("CODEX_COMPUTER_USE_STATE", "/srv/state/codex/computer-use"))
DESKTOP_COMMAND = os.environ.get("CODEX_DESKTOP_COMMAND", "codex-desktop")
ID_RE = re.compile(r"^[A-Za-z0-9_.-]+$")
LOCAL_UPSTREAMS = {"127.0.0.1", "localhost", "::1"}
HOP_BY_HOP_HEADERS = {
    "connection",
    "keep-alive",
    "proxy-authenticate",
    "proxy-authorization",
    "te",
    "trailer",
    "transfer-encoding",
    "upgrade",
}


class LauncherError(RuntimeError):
    pass


def run_launcher(args, timeout=60):
    proc = subprocess.run(
        [DESKTOP_COMMAND, *args],
        check=False,
        capture_output=True,
        text=True,
        timeout=timeout,
    )
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"exit {proc.returncode}"
        raise LauncherError(detail)
    return proc.stdout


def parse_launcher_json(args, timeout=60):
    output = run_launcher(args, timeout=timeout)
    try:
        return json.loads(output)
    except json.JSONDecodeError as exc:
        raise LauncherError(f"launcher returned invalid JSON: {exc}") from exc


def valid_desktop_id(desktop_id):
    return bool(desktop_id and ID_RE.fullmatch(desktop_id))


def list_desktops():
    desktops = parse_launcher_json(["list", "--json"], timeout=30)
    if not isinstance(desktops, list):
        raise LauncherError("desktop list did not return an array")
    return sorted(desktops, key=lambda item: item.get("startedAt", ""), reverse=True)


def status_desktop(desktop_id):
    if not valid_desktop_id(desktop_id):
        raise LauncherError("invalid desktop id")
    desktop = parse_launcher_json(["status", "--json", desktop_id], timeout=30)
    if not isinstance(desktop, dict):
        raise LauncherError("desktop status did not return an object")
    return desktop


def start_desktop(profile, width, height, ttl_seconds):
    args = [
        "start",
        "--json",
        "--profile",
        profile,
        "--width",
        str(width),
        "--height",
        str(height),
        "--ttl",
        str(ttl_seconds),
    ]
    desktop = parse_launcher_json(args, timeout=90)
    if not isinstance(desktop, dict) or not valid_desktop_id(str(desktop.get("id", ""))):
        raise LauncherError("desktop start did not return a usable desktop id")
    return desktop


def stop_desktop(desktop_id):
    if not valid_desktop_id(desktop_id):
        raise LauncherError("invalid desktop id")
    return run_launcher(["stop", desktop_id], timeout=30)


def prune_desktops():
    return run_launcher(["prune"], timeout=60)


def form_int(fields, name, default, minimum, maximum):
    raw = fields.get(name, [str(default)])[0]
    try:
        value = int(raw)
    except ValueError as exc:
        raise LauncherError(f"{name} must be an integer") from exc
    if not minimum <= value <= maximum:
        raise LauncherError(f"{name} must be between {minimum} and {maximum}")
    return value


def fmt_time(value):
    if not value:
        return "-"
    return html.escape(str(value))


def desktop_open_path(desktop_id):
    return f"/desktop/{quote(desktop_id)}/"


