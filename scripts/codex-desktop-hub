def render_dashboard(*, status=None, error=None):
    try:
        desktops = list_desktops()
    except LauncherError as exc:
        desktops = []
        error = error or str(exc)

    running = [item for item in desktops if item.get("status") == "running" and item.get("ready")]
    start_form = """
<section class="panel">
  <form method="post" action="/start">
    <label>Profile
      <select name="profile">
        <option value="browser">Browser</option>
        <option value="terminal">Terminal</option>
        <option value="blank">Blank</option>
      </select>
    </label>
    <label>Width <input name="width" inputmode="numeric" value="1440"></label>
    <label>Height <input name="height" inputmode="numeric" value="1000"></label>
    <label>TTL seconds <input name="ttl" inputmode="numeric" value="14400"></label>
    <button type="submit">Start Desktop</button>
  </form>
</section>
"""

    if desktops:
        rows = []
        for item in desktops:
            desktop_id = str(item.get("id", ""))
            escaped_id = html.escape(desktop_id)
            status_name = str(item.get("status", "unknown"))
            is_running = status_name == "running" and bool(item.get("ready"))
            status_class = " running" if is_running else ""
            size = f"{item.get('width', '-') or '-'}x{item.get('height', '-') or '-'}"
            web_port = item.get("webPort", "-")
            actions = []
            if is_running and valid_desktop_id(desktop_id):
                actions.append(f'<a class="button" href="{desktop_open_path(desktop_id)}">Open</a>')
                actions.append(
                    f'<form method="post" action="/stop/{quote(desktop_id)}">'
                    '<button class="danger" type="submit">Stop</button></form>'
                )
            rows.append(
                f"""
<article class="desktop">
  <div>
    <h2><code>{escaped_id}</code></h2>
    <div class="meta">
      <span class="pill{status_class}">{html.escape(status_name)}</span>
      <span class="pill">{html.escape(str(item.get("profile", "-") or "-"))}</span>
      <span class="pill">DISPLAY {html.escape(str(item.get("display", "-") or "-"))}</span>
      <span class="pill">{html.escape(size)}</span>
      <span class="pill">noVNC {html.escape(str(web_port))}</span>
      <span class="pill">started {fmt_time(item.get("startedAt"))}</span>
      <span class="pill">expires {fmt_time(item.get("expiresAt"))}</span>
    </div>
  </div>
  <div class="actions">
    {''.join(actions) if actions else '<span class="pill">not ready</span>'}
  </div>
</article>"""
            )
        list_html = '<section class="grid">' + "\n".join(rows) + "</section>"
    else:
        list_html = '<section class="panel empty">No desktops are running.</section>'

    prune_form = """
<section class="panel">
  <form method="post" action="/prune">
    <button class="secondary" type="submit">Prune Stopped Desktops</button>
  </form>
</section>
"""
    summary = f"<p>{len(running)} ready desktop{'s' if len(running) != 1 else ''}.</p>"
    body = start_form + f'<section class="panel">{summary}</section>' + list_html + prune_form
    return html_page("Codex Desktops", body, status=status, error=error)


def external_vnc_query(handler, desktop_id):
    forwarded_host = handler.headers.get("X-Forwarded-Host") or handler.headers.get("Host") or ""
    forwarded_proto = handler.headers.get("X-Forwarded-Proto") or "http"
    host = forwarded_host.split(":", 1)[0] if forwarded_host else HOST
    port = ""
    if ":" in forwarded_host and not forwarded_host.startswith("["):
        port = forwarded_host.rsplit(":", 1)[1]
    elif forwarded_proto == "https":
        port = "443"
    elif forwarded_proto == "http":
        port = "80"

    params = {
        "host": host,
        "path": f"desktop/{desktop_id}/websockify",
        "autoconnect": "1",
        "resize": "scale",
        "reconnect": "1",
    }
    if port:
        params["port"] = port
    if forwarded_proto == "https":
        params["encrypt"] = "1"
    return urlencode(params)


class DesktopHubHandler(BaseHTTPRequestHandler):
    server_version = "codex-desktop-hub/0.1"

    def send_text(self, status, text, content_type="text/plain; charset=utf-8"):
        data = text.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-store")
        self.send_header("X-Robots-Tag", "noindex, nofollow")
        self.end_headers()
        self.wfile.write(data)

    def redirect(self, location):
        self.send_response(HTTPStatus.SEE_OTHER)
        self.send_header("Location", location)
        self.send_header("Cache-Control", "no-store")
        self.end_headers()

    def read_form(self):
        length = int(self.headers.get("Content-Length", "0") or "0")
        if length > 1_000_000:
            raise LauncherError("request body is too large")
        body = self.rfile.read(length).decode("utf-8")
        return parse_qs(body)

    def do_GET(self):
        split = urlsplit(self.path)
        if split.path == "/healthz":
            self.send_text(HTTPStatus.OK, "ok\n")
            return
        if split.path == "/api/desktops":
            try:
                payload = json.dumps(list_desktops(), indent=2).encode("utf-8")
                self.send_response(HTTPStatus.OK)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(payload)))
                self.send_header("Cache-Control", "no-store")
                self.end_headers()
                self.wfile.write(payload)
            except LauncherError as exc:
                self.send_text(HTTPStatus.INTERNAL_SERVER_ERROR, f"{exc}\n")
            return
        if split.path == "/":
            self.send_text(HTTPStatus.OK, render_dashboard(), "text/html; charset=utf-8")
            return
        if split.path.startswith("/desktop/"):
            self.handle_desktop_proxy(split)
            return
        self.send_text(HTTPStatus.NOT_FOUND, "not found\n")

    def do_HEAD(self):
        split = urlsplit(self.path)
        if split.path.startswith("/desktop/"):
            self.handle_desktop_proxy(split)
            return
        self.send_response(HTTPStatus.OK if split.path in {"/", "/healthz"} else HTTPStatus.NOT_FOUND)
        self.end_headers()

    def do_POST(self):
        split = urlsplit(self.path)
        try:
            if split.path == "/start":
                fields = self.read_form()
                profile = fields.get("profile", ["browser"])[0]
                if profile not in {"browser", "terminal", "blank"}:
                    raise LauncherError("unknown profile")
                width = form_int(fields, "width", 1440, 640, 3840)
                height = form_int(fields, "height", 1000, 480, 2160)
                ttl_seconds = form_int(fields, "ttl", 14400, 300, 86400)
                desktop = start_desktop(profile, width, height, ttl_seconds)
                self.redirect(desktop_open_path(str(desktop["id"])))
                return
            if split.path.startswith("/stop/"):
                desktop_id = split.path.removeprefix("/stop/")
                if not valid_desktop_id(desktop_id):
                    raise LauncherError("invalid desktop id")
                stop_desktop(desktop_id)
                self.redirect("/")
                return
            if split.path == "/prune":
                prune_desktops()
                self.redirect("/")
                return
        except LauncherError as exc:
            self.send_text(
                HTTPStatus.INTERNAL_SERVER_ERROR,
                render_dashboard(error=str(exc)),
                "text/html; charset=utf-8",
            )
            return

        if split.path.startswith("/desktop/"):
            self.handle_desktop_proxy(split)
            return
        self.send_text(HTTPStatus.NOT_FOUND, "not found\n")

    def handle_desktop_proxy(self, split):
        match = re.fullmatch(r"/desktop/([^/]+)(/.*)?", split.path)
        if not match:
            self.send_text(HTTPStatus.NOT_FOUND, "unknown desktop route\n")
            return

        desktop_id = match.group(1)
        suffix = match.group(2) or "/"
        if not valid_desktop_id(desktop_id):
            self.send_text(HTTPStatus.BAD_REQUEST, "invalid desktop id\n")
            return

        if suffix == "/":
            query = external_vnc_query(self, desktop_id)
            self.redirect(f"/desktop/{quote(desktop_id)}/vnc.html?{query}")
            return

        try:
            desktop = status_desktop(desktop_id)
            upstream_host = str(desktop.get("listenHost") or "127.0.0.1")
            upstream_port = int(desktop.get("webPort") or 0)
        except (LauncherError, ValueError) as exc:
            self.send_text(HTTPStatus.BAD_GATEWAY, f"{exc}\n")
            return

        if desktop.get("status") != "running" or not desktop.get("ready"):
            self.send_text(HTTPStatus.CONFLICT, "desktop is not running\n")
            return
        if upstream_host not in LOCAL_UPSTREAMS or upstream_port <= 0:
            self.send_text(HTTPStatus.BAD_GATEWAY, "desktop has no local noVNC endpoint\n")
            return

        upstream_path = suffix
        if split.query:
            upstream_path = f"{upstream_path}?{split.query}"

        if self.is_websocket_upgrade():
            self.proxy_websocket(upstream_host, upstream_port, upstream_path)
        else:
            self.proxy_http(upstream_host, upstream_port, upstream_path)

    def is_websocket_upgrade(self):
        connection = self.headers.get("Connection", "")
        upgrade = self.headers.get("Upgrade", "")
        return "upgrade" in connection.lower() and upgrade.lower() == "websocket"

    def proxy_http(self, upstream_host, upstream_port, upstream_path):
        body = None
        if self.command in {"POST", "PUT", "PATCH"}:
            length = int(self.headers.get("Content-Length", "0") or "0")
            body = self.rfile.read(length) if length else None

        headers = {
            key: value
            for key, value in self.headers.items()
            if key.lower() not in HOP_BY_HOP_HEADERS and key.lower() != "host"
        }
        headers["Host"] = f"{upstream_host}:{upstream_port}"

        conn = HTTPConnection(upstream_host, upstream_port, timeout=30)
        try:
            conn.request(self.command, upstream_path, body=body, headers=headers)
            response = conn.getresponse()
            self.send_response(response.status, response.reason)
            for key, value in response.getheaders():
                if key.lower() not in HOP_BY_HOP_HEADERS:
                    self.send_header(key, value)
            self.end_headers()
            if self.command != "HEAD":
                shutil.copyfileobj(response, self.wfile)
        except OSError as exc:
            self.send_text(HTTPStatus.BAD_GATEWAY, f"noVNC proxy failed: {exc}\n")
        finally:
            conn.close()

    def proxy_websocket(self, upstream_host, upstream_port, upstream_path):
        self.close_connection = True
        try:
            upstream = socket.create_connection((upstream_host, upstream_port), timeout=10)
        except OSError as exc:
            self.send_text(HTTPStatus.BAD_GATEWAY, f"websocket connect failed: {exc}\n")
            return

        try:
            request = [f"{self.command} {upstream_path} {self.request_version}\r\n"]
            request.append(f"Host: {upstream_host}:{upstream_port}\r\n")
            for key, value in self.headers.items():
                if key.lower() != "host":
                    request.append(f"{key}: {value}\r\n")
            request.append("\r\n")
            upstream.sendall("".join(request).encode("iso-8859-1"))

            sockets = [self.connection, upstream]
            for sock in sockets:
                sock.setblocking(False)

            deadline = time.monotonic() + 8 * 60 * 60
            while time.monotonic() < deadline:
                readable, _, errored = select.select(sockets, [], sockets, 60)
                if errored:
                    break
                if not readable:
                    continue
                for sock in readable:
                    try:
                        data = sock.recv(65536)
                    except BlockingIOError:
                        continue
                    if not data:
                        return
                    target = upstream if sock is self.connection else self.connection
                    target.sendall(data)
        finally:
            upstream.close()


def main():
    STATE_ROOT.mkdir(parents=True, exist_ok=True)
    httpd = ThreadingHTTPServer((HOST, PORT), DesktopHubHandler)
    httpd.daemon_threads = True
    print(f"codex-desktop-hub listening on http://{HOST}:{PORT}", flush=True)
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        httpd.server_close()


if __name__ == "__main__":
    try:
        main()
    except Exception as exc:
        print(f"codex-desktop-hub: {exc}", file=sys.stderr)
        raise
