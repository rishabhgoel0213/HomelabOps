#!/usr/bin/env bash
set -euo pipefail

. "${HOMELAB_PATHS_LIB:-/srv/ops/scripts/lib/homelab-paths}"

for path in "$homelab_public_site_source" "$homelab_resume_pdf"; do
  if [[ ! -e "$path" ]]; then
    echo "Missing required public-site source: $path" >&2
    exit 1
  fi
done

sudo install -d -m 0755 -o caddy -g caddy "$homelab_public_site_state"
sudo rsync -a --delete --chmod=D755,F644 "$homelab_public_site_source/" "$homelab_public_site_state/"
sudo install -m 0644 -o caddy -g caddy "$homelab_resume_pdf" "$homelab_public_site_state/rishabh-goel-resume.pdf"
sudo chown -R caddy:caddy "$homelab_public_site_state"

echo "Deployed public site to $homelab_public_site_state"
