#!/usr/bin/env bash
set -euo pipefail

repo="${1:-rishabhgoel0213/rishabhgoel0213}"
source_readme="/srv/ops/documents/github-profile/README.md"

if [[ ! -f "$source_readme" ]]; then
  echo "Missing managed README source: $source_readme" >&2
  exit 1
fi

tmpdir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmpdir"
}
trap cleanup EXIT

gh repo clone "$repo" "$tmpdir/repo" -- --depth 1

cd "$tmpdir/repo"
branch="$(git branch --show-current)"
git config user.name "Rishabh Goel"
git config user.email "rishabhgoel0213@gmail.com"

git rm -r --ignore-unmatch .
install -m 0644 "$source_readme" README.md
git add README.md

if git diff --cached --quiet; then
  echo "$repo is already synced to $source_readme."
  exit 0
fi

git commit -m "Keep profile repo README only"
git push origin "$branch"
