#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 3 || $# -gt 4 ]]; then
  echo "usage: scripts/add-route NAME internal|public|public-protected UPSTREAM [HOST]" >&2
  exit 2
fi

name="$1"
visibility="$2"
upstream="$3"
host="${4:-$name}"

case "$visibility" in
  internal|public|public-protected) ;;
  *)
    echo "visibility must be internal, public, or public-protected" >&2
    exit 2
    ;;
esac

case "$upstream" in
  http://*|https://*)
    ;;
  *)
    echo "upstream must start with http:// or https://" >&2
    exit 2
    ;;
esac

tmp="$(mktemp)"
jq \
  --arg name "$name" \
  --arg host "$host" \
  --arg visibility "$visibility" \
  --arg upstream "$upstream" \
  '.[$name] = {
    enable: true,
    host: $host,
    visibility: $visibility,
    upstream: $upstream,
    description: "User-managed route"
  }' \
  routes/apps.json > "$tmp"
mv "$tmp" routes/apps.json

echo "Added route '$name'. Run: just routes && just switch"
