#!/usr/bin/env bash
set -euo pipefail

if [[ -r /etc/homelab/paths.env ]]; then
  # shellcheck disable=SC1091
  . /etc/homelab/paths.env
fi

state_root="${EDEN_STATE_ROOT:-${homelab_state_root:-/srv/state}/eden}"
eden_command="${EDEN_EXECUTABLE:-eden}"
desktop_user="${EDEN_DESKTOP_USER:-rishabh}"
desktop_group="${EDEN_DESKTOP_GROUP:-users}"
listen_host="${EDEN_LISTEN_HOST:-127.0.0.1}"
display="${EDEN_DISPLAY:-:87}"
vnc_port="${EDEN_VNC_PORT:-5997}"
web_port="${EDEN_WEB_PORT:-6097}"
width="${EDEN_WIDTH:-1920}"
height="${EDEN_HEIGHT:-1080}"
novnc_web_root="${EDEN_NOVNC_WEB_ROOT:-}"
xorg_module_path="${EDEN_XORG_MODULE_PATH:-}"
vk_icd_filenames="${VK_ICD_FILENAMES:-/run/opengl-driver/share/vulkan/icd.d/nvidia_icd.json}"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

need_executable() {
  local command="$1"
  if [[ "$command" == */* ]]; then
    if [[ ! -x "$command" ]]; then
      echo "Missing required executable: $command" >&2
      exit 1
    fi
  else
    need "$command"
  fi
}

port_is_listening() {
  local port="$1"
  ss -ltn | awk '{print $4}' | grep -Eq "[:.]${port}$"
}

need ss
need Xorg
need xdpyinfo
need openbox
need runuser
need x11vnc
need_executable "$eden_command"

if [[ "$(id -u)" -eq 0 ]]; then
  install -d -o "$desktop_user" -g "$desktop_group" -m 0700 \
    "$state_root" \
    "$state_root/home" \
    "$state_root/runtime" \
    "$state_root/config" \
    "$state_root/cache" \
    "$state_root/data" \
    "$state_root/log"
  install -d -o "$desktop_user" -g "$desktop_group" -m 0750 "$state_root/games"
else
  mkdir -p "$state_root"/{home,runtime,config,cache,data,log,games}
  chmod 700 "$state_root" "$state_root"/{home,runtime,config,cache,data,log}
  chmod 750 "$state_root/games"
fi

export HOME="$state_root/home"
export XDG_RUNTIME_DIR="$state_root/runtime"
export XDG_CONFIG_HOME="$state_root/config"
export XDG_CACHE_HOME="$state_root/cache"
export XDG_DATA_HOME="$state_root/data"
export DISPLAY="$display"
export GDK_BACKEND=x11
export QT_QPA_PLATFORM=xcb
export SDL_VIDEODRIVER=x11
export NO_AT_BRIDGE=1
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export GBM_BACKEND=nvidia-drm
export VK_ICD_FILENAMES="$vk_icd_filenames"

chmod 700 "$XDG_RUNTIME_DIR"

pids=()
cleanup() {
  for child_pid in "${pids[@]:-}"; do
    kill "$child_pid" >/dev/null 2>&1 || true
  done
}
trap cleanup EXIT INT TERM

user_env=(
  "HOME=$HOME"
  "XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR"
  "XDG_CONFIG_HOME=$XDG_CONFIG_HOME"
  "XDG_CACHE_HOME=$XDG_CACHE_HOME"
  "XDG_DATA_HOME=$XDG_DATA_HOME"
  "DISPLAY=$DISPLAY"
  "GDK_BACKEND=$GDK_BACKEND"
  "QT_QPA_PLATFORM=$QT_QPA_PLATFORM"
  "SDL_VIDEODRIVER=$SDL_VIDEODRIVER"
  "NO_AT_BRIDGE=$NO_AT_BRIDGE"
  "__GLX_VENDOR_LIBRARY_NAME=$__GLX_VENDOR_LIBRARY_NAME"
  "GBM_BACKEND=$GBM_BACKEND"
  "VK_ICD_FILENAMES=$VK_ICD_FILENAMES"
)

run_as_desktop_user() {
  if [[ "$(id -u)" -eq 0 ]]; then
    runuser -u "$desktop_user" -- env "${user_env[@]}" "$@"
  else
    env "${user_env[@]}" "$@"
  fi
}

xorg_config="$state_root/xorg-nvidia.conf"
cat > "$xorg_config" <<EOF
Section "ServerLayout"
    Identifier "EdenLayout"
    Screen 0 "EdenScreen" 0 0
EndSection

Section "Device"
    Identifier "EdenNvidia"
    Driver "nvidia"
    Option "AllowEmptyInitialConfiguration" "true"
    Option "UseDisplayDevice" "none"
    Option "Coolbits" "0"
EndSection

Section "Screen"
    Identifier "EdenScreen"
    Device "EdenNvidia"
    DefaultDepth 24
    Option "AllowEmptyInitialConfiguration" "true"
    SubSection "Display"
        Depth 24
        Virtual $width $height
    EndSubSection
EndSection
EOF
if [[ "$(id -u)" -eq 0 ]]; then
  chown "$desktop_user:$desktop_group" "$xorg_config"
fi

xorg_args=(
  "$DISPLAY"
  "-config" "$xorg_config"
  "-logfile" "$state_root/log/xorg.log"
  "-nolisten" "tcp"
  "-noreset"
  "-ac"
  "+extension" "GLX"
  "+extension" "RANDR"
  "+extension" "RENDER"
)
if [[ -n "$xorg_module_path" ]]; then
  xorg_args+=("-modulepath" "$xorg_module_path")
fi

Xorg "${xorg_args[@]}" > "$state_root/log/xorg.stdout.log" 2>&1 &
pids+=("$!")

display_ready=0
for _ in $(seq 1 80); do
  if xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
    display_ready=1
    break
  fi
  sleep 0.25
done
if (( display_ready == 0 )); then
  echo "NVIDIA Xorg did not become ready on $DISPLAY" >&2
  exit 1
fi

run_as_desktop_user openbox > "$state_root/log/openbox.log" 2>&1 &
pids+=("$!")

x11vnc -display "$DISPLAY" -listen "$listen_host" -nopw -forever -shared \
  -rfbport "$vnc_port" -o "$state_root/log/x11vnc.log" \
  > "$state_root/log/x11vnc.stdout.log" 2>&1 &
pids+=("$!")

novnc_started=0
if command -v novnc_proxy >/dev/null 2>&1; then
  novnc_proxy --listen "$listen_host:$web_port" --vnc "$listen_host:$vnc_port" \
    > "$state_root/log/novnc.log" 2>&1 &
  pids+=("$!")
  novnc_started=1
elif command -v websockify >/dev/null 2>&1; then
  web_roots=()
  if [[ -n "$novnc_web_root" ]]; then
    web_roots+=("$novnc_web_root")
  fi
  web_roots+=(
    /run/current-system/sw/share/novnc
    /run/current-system/sw/share/noVNC
    /run/current-system/sw/share/webapps/novnc
  )
  for web_root in "${web_roots[@]}"; do
    if [[ -d "$web_root" ]]; then
      websockify --web "$web_root" "$listen_host:$web_port" "$listen_host:$vnc_port" \
        > "$state_root/log/novnc.log" 2>&1 &
      pids+=("$!")
      novnc_started=1
      break
    fi
  done
fi
if (( novnc_started == 0 )); then
  echo "No noVNC launcher or websockify web root is available" >&2
  exit 1
fi

novnc_ready=0
for _ in $(seq 1 40); do
  if port_is_listening "$web_port"; then
    novnc_ready=1
    break
  fi
  sleep 0.25
done
if (( novnc_ready == 0 )); then
  echo "noVNC did not begin listening on $listen_host:$web_port" >&2
  exit 1
fi

cd "$state_root/games"
run_as_desktop_user "$eden_command" > "$state_root/log/eden.log" 2>&1 &
pids+=("$!")

wait -n "${pids[@]}"
