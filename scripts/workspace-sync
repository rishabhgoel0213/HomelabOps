#!/usr/bin/env bash
set -euo pipefail

. "${HOMELAB_PATHS_LIB:-/srv/ops/scripts/lib/homelab-paths}"

source_dir="${1:-$homelab_workspace_source}"
target_dir="${2:-$homelab_workspace_root}"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

need find
need git
need install
need rsync
need sudo

if [[ ! -d "$source_dir" ]]; then
  echo "Missing workspace source: $source_dir" >&2
  exit 1
fi

sudo install -d -m 0755 -o "$homelab_user" -g "$homelab_group" "$target_dir"
sudo install -d -m 0755 -o "$homelab_user" -g "$homelab_group" \
  "$target_dir/docs" \
  "$target_dir/repos" \
  "$target_dir/scratch" \
  "$target_dir/scripts" \
  "$target_dir/tmp"

rsync -a --chmod=D755,F644 \
  --exclude '/repos/' \
  --exclude '/scratch/' \
  --exclude '/tmp/' \
  "$source_dir"/ "$target_dir"/

if [[ -d "$target_dir/scripts" ]]; then
  find "$target_dir/scripts" -type f -exec chmod 0755 {} +
fi

if ! git -C "$target_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git -C "$target_dir" init --initial-branch=main
fi

git -C "$target_dir" config user.name "Codex Workspace"
git -C "$target_dir" config user.email "codex-workspace@nixos-pc.local"
git -C "$target_dir" add AGENTS.md README.md flake.nix .gitignore docs scripts

if git -C "$target_dir" diff --cached --quiet; then
  echo "Workspace scaffold is already synced at $target_dir." >&2
elif git -C "$target_dir" rev-parse --verify HEAD >/dev/null 2>&1; then
  git -C "$target_dir" commit -m "Sync Codex workspace scaffold"
else
  git -C "$target_dir" commit -m "Initialize Codex workspace"
fi

echo "Synced Codex workspace scaffold to $target_dir." >&2
