#!/usr/bin/env python3
import json
import os
import re
import subprocess
import sys
import threading
from pathlib import Path


VERSION = "0.1.0"
LAUNCHER = os.environ.get("CODEX_DESKTOP_COMMAND", "codex-desktop")
OPEN_COMPUTER_USE = os.environ.get("OPEN_COMPUTER_USE_COMMAND", "open-computer-use")


KEY_ALIASES = {
    "enter": "Return",
    "return": "Return",
    "escape": "Escape",
    "esc": "Escape",
    "backspace": "BackSpace",
    "delete": "Delete",
    "del": "Delete",
    "tab": "Tab",
    "space": "space",
    "up": "Up",
    "down": "Down",
    "left": "Left",
    "right": "Right",
}

MODIFIER_ALIASES = {
    "cmd": "super",
    "command": "super",
    "control": "ctrl",
    "ctl": "ctrl",
    "option": "alt",
}


def log(message):
    print(message, file=sys.stderr, flush=True)


def read_message(stream):
    while True:
        line = stream.readline()
        if line == b"":
            return None
        if line.strip():
            break

    if line.lower().startswith(b"content-length:"):
        length = int(line.split(b":", 1)[1].strip())
        while True:
            header = stream.readline()
            if header in (b"\r\n", b"\n", b""):
                break
        payload = stream.read(length)
        return json.loads(payload.decode("utf-8"))

    return json.loads(line.decode("utf-8"))


def write_message(message):
    data = json.dumps(message, separators=(",", ":"), ensure_ascii=False)
    sys.stdout.write(data + "\n")
    sys.stdout.flush()


def rpc_result(request_id, result):
    write_message({"jsonrpc": "2.0", "id": request_id, "result": result})


def rpc_error(request_id, code, message, data=None):
    error = {"code": code, "message": message}
    if data is not None:
        error["data"] = data
    write_message({"jsonrpc": "2.0", "id": request_id, "error": error})


def tool_text(text, is_error=False):
    return {
        "content": [{"type": "text", "text": str(text)}],
        "isError": bool(is_error),
    }


def run_launcher(args, check=True):
    proc = subprocess.run(
        [LAUNCHER] + args,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if check and proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"{LAUNCHER} exited {proc.returncode}"
        raise RuntimeError(detail)
    return proc.stdout


def load_desktops():
    output = run_launcher(["list", "--json"])
    return json.loads(output or "[]")


def live_desktops():
    return [item for item in load_desktops() if item.get("status") == "running" and item.get("ready")]


def start_desktop(args):
    command = ["start", "--json"]
    for key, flag in [
        ("id", "--id"),
        ("profile", "--profile"),
        ("width", "--width"),
        ("height", "--height"),
        ("ttl_seconds", "--ttl"),
        ("listen_host", "--listen-host"),
        ("public_host", "--public-host"),
    ]:
        value = args.get(key)
        if value is not None:
            command.extend([flag, str(value)])

    user_command = args.get("command")
    if isinstance(user_command, str) and user_command.strip():
        command.extend(["--", "bash", "-lc", user_command])
    elif isinstance(user_command, list) and user_command:
        command.append("--")
        command.extend(str(item) for item in user_command)

    return json.loads(run_launcher(command))


def result_has_image(result):
    for item in result.get("content", []):
        if item.get("type") == "image" and item.get("data") and item.get("mimeType"):
            return True
    return False


def top_frame_geometry(result):
    frame_re = re.compile(
        r"Frame:\s*\{x:\s*(-?\d+),\s*y:\s*(-?\d+),\s*width:\s*(\d+),\s*height:\s*(\d+)\}"
    )
    for item in result.get("content", []):
        if item.get("type") != "text":
            continue
        match = frame_re.search(item.get("text", ""))
        if not match:
            continue
        x, y, width, height = (int(value) for value in match.groups())
        if width <= 0 or height <= 0:
            continue
        return f"{width}x{height}+{max(x, 0)}+{max(y, 0)}"
    return None


def add_desktop_screenshot(result, desktop_id):
    if result_has_image(result):
        return result

    command = ["screenshot", "--json"]
    geometry = top_frame_geometry(result)
    if geometry:
        command.extend(["--geometry", geometry])
    command.append(desktop_id)

    try:
        screenshot = json.loads(run_launcher(command))
    except Exception as exc:
        content = list(result.get("content", []))
        content.append({
            "type": "text",
            "text": f"Desktop screenshot fallback failed: {exc}",
        })
        enriched = dict(result)
        enriched["content"] = content
        return enriched

    content = list(result.get("content", []))
    content.append({
        "type": "image",
        "mimeType": screenshot.get("mimeType", "image/png"),
        "data": screenshot["data"],
    })
    enriched = dict(result)
    enriched["content"] = content
    return enriched


def normalize_key_name(name):
    if not name:
        return name
    lowered = name.strip().lower()
    return KEY_ALIASES.get(lowered) or MODIFIER_ALIASES.get(lowered) or name.strip()


def normalize_key_combo(key):
    parts = [part for part in re.split(r"\s*\+\s*", str(key).strip()) if part]
    if not parts:
        raise RuntimeError("Missing key")
    return "+".join(normalize_key_name(part) for part in parts)


def desktop_env(desktop_id):
    env_json = run_launcher(["env-json", desktop_id])
    values = json.loads(env_json)
    env = os.environ.copy()
    env.update({key: str(value) for key, value in values.items() if value is not None})
    return env


def press_desktop_key(desktop_id, key):
    key_spec = normalize_key_combo(key)
    proc = subprocess.run(
        ["xdotool", "key", "--clearmodifiers", key_spec],
        env=desktop_env(desktop_id),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or f"xdotool exited {proc.returncode}"
        raise RuntimeError(detail)
    return tool_text(f"Pressed key: {key_spec}")


class ChildMCP:
    def __init__(self, desktop):
        self.desktop = desktop
        self.request_id = 0
        self.lock = threading.Lock()
        self.proc = None
        self.stderr_file = None
        self.start()

    def start(self):
        env_json = run_launcher(["env-json", self.desktop["id"]])
        desktop_env = json.loads(env_json)
        env = os.environ.copy()
        env.update({key: str(value) for key, value in desktop_env.items() if value is not None})

        workdir = Path(self.desktop["directory"])
        log_path = workdir / "open-computer-use-mcp.log"
        self.stderr_file = log_path.open("ab")
        self.proc = subprocess.Popen(
            [OPEN_COMPUTER_USE, "mcp"],
            cwd=str(workdir),
            env=env,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=self.stderr_file,
        )
        self.request("initialize", {
            "protocolVersion": "2024-11-05",
            "capabilities": {},
            "clientInfo": {"name": "codex-computer-use-broker", "version": VERSION},
        })
        self.notify("notifications/initialized", {})

    def close(self):
        if self.proc and self.proc.poll() is None:
            self.proc.terminate()
        if self.stderr_file:
            self.stderr_file.close()

    def notify(self, method, params=None):
        message = {"jsonrpc": "2.0", "method": method}
        if params is not None:
            message["params"] = params
        self._write(message)

    def request(self, method, params=None):
        with self.lock:
            self.request_id += 1
            request_id = self.request_id
            message = {"jsonrpc": "2.0", "id": request_id, "method": method}
            if params is not None:
                message["params"] = params
            self._write(message)
            while True:
                response = read_message(self.proc.stdout)
                if response is None:
                    raise RuntimeError("open-computer-use MCP server exited")
                if response.get("id") == request_id:
                    if "error" in response:
                        error = response["error"]
                        raise RuntimeError(error.get("message", str(error)))
                    return response.get("result", {})

    def call_tool(self, name, args):
        return self.request("tools/call", {"name": name, "arguments": args})

    def _write(self, message):
        if self.proc.poll() is not None:
            raise RuntimeError("open-computer-use MCP server is not running")
        payload = json.dumps(message, separators=(",", ":"), ensure_ascii=False).encode("utf-8") + b"\n"
        self.proc.stdin.write(payload)
        self.proc.stdin.flush()


class Broker:
    def __init__(self):
        self.children = {}

    def close(self):
        for child in self.children.values():
            child.close()

    def handle(self, message):
        method = message.get("method")
        request_id = message.get("id")

        try:
            if method == "initialize":
                rpc_result(request_id, {
                    "protocolVersion": message.get("params", {}).get("protocolVersion", "2024-11-05"),
                    "capabilities": {"tools": {}},
                    "serverInfo": {"name": "codex-computer-use", "version": VERSION},
                })
            elif method in ("notifications/initialized", "initialized"):
                return
            elif method == "ping":
                rpc_result(request_id, {})
            elif method == "tools/list":
                rpc_result(request_id, {"tools": tools()})
            elif method == "tools/call":
                result = self.call_tool(message.get("params", {}))
                rpc_result(request_id, result)
            elif method == "resources/list":
                rpc_result(request_id, {"resources": []})
            elif method == "prompts/list":
                rpc_result(request_id, {"prompts": []})
            elif request_id is not None:
                rpc_error(request_id, -32601, f"Method not found: {method}")
        except Exception as exc:
            if request_id is None:
                log(f"notification failed: {exc}")
            else:
                rpc_result(request_id, tool_text(exc, is_error=True))

    def call_tool(self, params):
        name = params.get("name")
        args = params.get("arguments") or {}

        if name == "desktop_start":
            return tool_text(json.dumps(start_desktop(args), indent=2))
        if name == "desktop_list":
            return tool_text(json.dumps(load_desktops(), indent=2))
        if name == "desktop_status":
            desktop_id = required(args, "desktop_id")
            return tool_text(run_launcher(["status", "--json", desktop_id]).strip())
        if name == "desktop_stop":
            desktop_id = required(args, "desktop_id")
            child = self.children.pop(desktop_id, None)
            if child is not None:
                child.close()
            return tool_text(run_launcher(["stop", desktop_id]).strip())
        if name == "desktop_vnc_url":
            desktop_id = required(args, "desktop_id")
            status = json.loads(run_launcher(["status", "--json", desktop_id]))
            return tool_text(json.dumps({
                "desktop_id": desktop_id,
                "web_url": status.get("webUrl"),
                "vnc_url": status.get("vncUrl"),
                "display": status.get("display"),
            }, indent=2))

        if name in computer_tool_names():
            desktop_id = self.resolve_desktop_id(args)
            if name == "press_key":
                return press_desktop_key(desktop_id, required(args, "key"))
            tool_args = dict(args)
            tool_args.pop("desktop_id", None)
            child = self.child_for(desktop_id)
            result = child.call_tool(name, tool_args)
            if name == "get_app_state":
                return add_desktop_screenshot(result, desktop_id)
            return result

        return tool_text(f"Unknown tool: {name}", is_error=True)

    def resolve_desktop_id(self, args):
        desktop_id = args.get("desktop_id")
        if desktop_id:
            return str(desktop_id)

        desktops = live_desktops()
        if len(desktops) == 1:
            return desktops[0]["id"]
        if len(desktops) == 0 and os.environ.get("CODEX_COMPUTER_USE_AUTO_START", "1") != "0":
            desktop = start_desktop({"profile": "browser"})
            return desktop["id"]
        if len(desktops) == 0:
            raise RuntimeError("No running desktop. Call desktop_start first.")
        raise RuntimeError("Multiple running desktops. Pass desktop_id explicitly.")

    def child_for(self, desktop_id):
        status = json.loads(run_launcher(["status", "--json", desktop_id]))
        if status.get("status") != "running" or not status.get("ready"):
            raise RuntimeError(f"Desktop is not ready: {desktop_id}")

        child = self.children.get(desktop_id)
        if child is not None and child.proc.poll() is None:
            return child

        if child is not None:
            child.close()
        child = ChildMCP(status)
        self.children[desktop_id] = child
        return child


def required(args, name):
    value = args.get(name)
    if value is None or value == "":
        raise RuntimeError(f"Missing required argument: {name}")
    return str(value)


def computer_tool_names():
    return [
        "list_apps",
        "get_app_state",
        "click",
        "perform_secondary_action",
        "scroll",
        "drag",
        "type_text",
        "press_key",
        "set_value",
    ]


def string_property(description):
    return {"type": "string", "description": description}


def number_property(description):
    return {"type": "number", "description": description}


def integer_property(description):
    return {"type": "integer", "description": description}


def desktop_id_property():
    return string_property("Desktop id from desktop_start or desktop_list. If omitted, the only running desktop is used; if none exists, a browser desktop is started automatically.")


def object_schema(properties, required_names=None):
    schema = {"type": "object", "properties": properties, "additionalProperties": False}
    if required_names:
        schema["required"] = required_names
    return schema


def tools():
    return [
        {
            "name": "desktop_start",
            "description": "Start a temporary Linux desktop capsule with Xvfb, VNC, noVNC, AT-SPI, and Open Computer Use support.",
            "inputSchema": object_schema({
                "id": string_property("Optional stable desktop id."),
                "profile": {"type": "string", "enum": ["browser", "terminal", "blank", "none"], "description": "Initial app profile. Defaults to browser."},
                "width": integer_property("Desktop width in pixels. Defaults to 1440."),
                "height": integer_property("Desktop height in pixels. Defaults to 1000."),
                "ttl_seconds": integer_property("Seconds before the desktop exits automatically. Defaults to 14400."),
                "command": {
                    "description": "Optional command to run inside the desktop. Use an argv array, or a shell string for bash -lc.",
                    "oneOf": [
                        {"type": "array", "items": {"type": "string"}},
                        {"type": "string"},
                    ],
                },
            }),
        },
        {
            "name": "desktop_list",
            "description": "List known temporary desktop capsules.",
