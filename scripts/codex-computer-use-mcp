                "element_index": string_property("Element index from get_app_state."),
                "action": string_property("Secondary action name."),
            }, ["app", "element_index", "action"]),
        },
        {
            "name": "scroll",
            "description": "Scroll an element in a direction.",
            "inputSchema": object_schema({
                "desktop_id": desktop_id_property(),
                "app": string_property("App name, window title, or process id."),
                "element_index": string_property("Element index from get_app_state."),
                "direction": {"type": "string", "enum": ["up", "down", "left", "right"]},
                "pages": number_property("Number of pages. Defaults to 1."),
            }, ["app", "element_index", "direction"]),
        },
        {
            "name": "drag",
            "description": "Drag between screenshot coordinates inside an app.",
            "inputSchema": object_schema({
                "desktop_id": desktop_id_property(),
                "app": string_property("App name, window title, or process id."),
                "from_x": number_property("Start X coordinate."),
                "from_y": number_property("Start Y coordinate."),
                "to_x": number_property("End X coordinate."),
                "to_y": number_property("End Y coordinate."),
