                "app": string_property("App name, window title, or process id."),
                "element_index": string_property("Element index from get_app_state."),
                "value": string_property("Value to assign."),
            }, ["app", "element_index", "value"]),
        },
    ]


def main():
    broker = Broker()
    try:
        while True:
            message = read_message(sys.stdin.buffer)
            if message is None:
                break
            broker.handle(message)
    finally:
        broker.close()


if __name__ == "__main__":
    main()
