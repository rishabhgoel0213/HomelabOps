#!/usr/bin/env bash
set -euo pipefail

repo="/srv/ops"
domain="therealrishabh.com"
account_id="${CLOUDFLARE_ACCOUNT_ID:?missing CLOUDFLARE_ACCOUNT_ID}"
zone_id="${CLOUDFLARE_ZONE_ID:?missing CLOUDFLARE_ZONE_ID}"
token="${CLOUDFLARE_API_TOKEN:?missing CLOUDFLARE_API_TOKEN}"
secrets_file="$repo/secrets/homelab.yaml"
age_key_cmd="/run/current-system/sw/bin/ssh-to-age -private-key -i /etc/ssh/ssh_host_ed25519_key"

tmpdir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmpdir"
  unset token
}
trap cleanup EXIT

plain_json="$tmpdir/plain.json"
updated_json="$tmpdir/updated.json"
encrypted_yaml="$tmpdir/homelab.yaml"

sudo env SOPS_AGE_KEY_CMD="$age_key_cmd" \
  sops --decrypt --output-type json "$secrets_file" > "$plain_json"
chmod 600 "$plain_json"

admin_env="CLOUDFLARE_API_TOKEN=$token
CLOUDFLARE_ACCOUNT_ID=$account_id
CLOUDFLARE_ZONE_ID=$zone_id
CLOUDFLARE_ZONE=$domain
"
dns_env="CLOUDFLARE_API_TOKEN=$token
CLOUDFLARE_DNS_API_TOKEN=$token
CLOUDFLARE_ZONE_API_TOKEN=$token
"

jq \
  --arg admin_env "$admin_env" \
  --arg dns_env "$dns_env" \
  '.["cloudflare-admin.env"] = $admin_env | .["cloudflare-dns.env"] = $dns_env' \
  "$plain_json" > "$updated_json"
chmod 600 "$updated_json"

(
  cd "$repo"
  sops --encrypt \
    --filename-override secrets/homelab.yaml \
    --input-type json \
    --output-type yaml \
    "$updated_json"
) > "$encrypted_yaml"
chmod 600 "$encrypted_yaml"

mv "$encrypted_yaml" "$secrets_file"
chmod 600 "$secrets_file"

sudo env SOPS_AGE_KEY_CMD="$age_key_cmd" \
  sops --decrypt "$secrets_file" >/dev/null

echo "Stored Cloudflare DNS token in encrypted sops file."
