#!/usr/bin/env bash
set -euo pipefail

. "${HOMELAB_PATHS_LIB:-/srv/ops/scripts/lib/homelab-paths}"

old_home="$homelab_user_home/.codex"
old_bin="$homelab_user_home/.local/bin/codex"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

need install
need rsync
need sudo

if [[ ! -d "$homelab_codex_home" ]]; then
  echo "Managed Codex home does not exist yet: $homelab_codex_home" >&2
  exit 1
fi

if [[ ! -f "$homelab_codex_home/config.toml" ]]; then
  echo "Managed Codex config does not exist yet: $homelab_codex_home/config.toml" >&2
  exit 1
fi

if [[ -L "$old_bin" ]]; then
  target="$(readlink "$old_bin")"
  if [[ "$target" == "$old_home"* ]]; then
    rm "$old_bin"
    echo "Removed legacy Codex shim: $old_bin" >&2
  else
    echo "Leaving $old_bin because it does not point into $old_home" >&2
  fi
elif [[ -e "$old_bin" ]]; then
  echo "Leaving non-symlink Codex file: $old_bin" >&2
fi

if [[ -d "$old_home" ]]; then
  open_fd="$(
    sudo find /proc/[0-9]*/fd -lname "$old_home*" -print -quit 2>/dev/null || true
  )"
  if [[ -n "$open_fd" ]]; then
    echo "Legacy Codex home still has open file descriptors: $open_fd" >&2
    echo "Finish or restart active Codex sessions, then rerun this command." >&2
    exit 1
  fi

  for subdir in sessions archived_sessions attachments shell_snapshots memories; do
    if [[ -d "$old_home/$subdir" ]]; then
      install -d -m 0700 "$homelab_codex_home/$subdir"
      rsync -a --update "$old_home/$subdir"/ "$homelab_codex_home/$subdir"/
    fi
  done

  sudo rm -rf "$old_home"
  echo "Deleted legacy user Codex home after syncing durable state to $homelab_codex_home." >&2
fi
