#!/usr/bin/env bash
set -euo pipefail

. "${HOMELAB_PATHS_LIB:-/srv/ops/scripts/lib/homelab-paths}"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

need install
need rsync
need sudo

source_home="${1:-$homelab_user_home/.codex}"

if [[ ! -d "$source_home" ]]; then
  echo "Missing source Codex home: $source_home" >&2
  exit 1
fi

sudo install -d -m 0700 -o "$homelab_user" -g "$homelab_group" "$homelab_codex_home"

rsync -a \
  --exclude 'packages/standalone' \
  --exclude 'app-server-control/*.sock' \
  "$source_home"/ "$homelab_codex_home"/

if [[ -f "$homelab_codex_config_source" && ! -f "$homelab_codex_home/config.toml" ]]; then
  install -m 0600 "$homelab_codex_config_source" "$homelab_codex_home/config.toml"
fi

if [[ -r /run/secrets/codex-auth.json ]]; then
  sudo install -m 0600 -o "$homelab_user" -g "$homelab_group" \
    /run/secrets/codex-auth.json \
    "$homelab_codex_home/auth.json"
fi
if [[ -r /run/secrets/codex-credentials.json ]]; then
  sudo install -m 0600 -o "$homelab_user" -g "$homelab_group" \
    /run/secrets/codex-credentials.json \
    "$homelab_codex_home/.credentials.json"
fi

sudo chown -R "$homelab_user:$homelab_group" "$homelab_codex_home"
sudo chmod 0700 "$homelab_codex_home"

echo "Migrated Codex state from $source_home to $homelab_codex_home." >&2
