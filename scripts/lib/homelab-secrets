#!/usr/bin/env bash

. "${HOMELAB_PATHS_LIB:-/srv/ops/scripts/lib/homelab-paths}"

repo="$homelab_ops_root"
sops_config="$homelab_sops_config"
secrets_file="$homelab_secrets_file"
age_key_cmd="${HOMELAB_AGE_KEY_CMD:-/run/current-system/sw/bin/ssh-to-age -private-key -i /etc/ssh/ssh_host_ed25519_key}"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

require_sops_file() {
  if [[ ! -f "$secrets_file" ]]; then
    echo "Missing $secrets_file" >&2
    exit 1
  fi
}

sops_decrypt_json() {
  local output_json="$1"
  sudo env SOPS_CONFIG="$sops_config" SOPS_AGE_KEY_CMD="$age_key_cmd" \
    sops --decrypt --output-type json "$secrets_file" > "$output_json"
  chmod 600 "$output_json"
}

sops_encrypt_json() {
  local input_json="$1"
  local encrypted_yaml="$2"

  sops --config "$sops_config" --encrypt \
    --filename-override "$secrets_file" \
    --input-type json \
    --output-type yaml \
    "$input_json" > "$encrypted_yaml"
  chmod 600 "$encrypted_yaml"
  mv "$encrypted_yaml" "$secrets_file"
  chmod 600 "$secrets_file"
}

sops_verify() {
  sudo env SOPS_CONFIG="$sops_config" SOPS_AGE_KEY_CMD="$age_key_cmd" \
    sops --decrypt "$secrets_file" >/dev/null
}
