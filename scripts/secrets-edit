#!/usr/bin/env bash
set -euo pipefail

. "${HOMELAB_SECRETS_LIB:-/srv/ops/scripts/lib/homelab-secrets}"

need install
need sops
need sudo

sudo install -d -m 0700 -o "$homelab_user" -g "$homelab_group" "$(dirname "$secrets_file")"

status=0
sudo env SOPS_CONFIG="$sops_config" SOPS_AGE_KEY_CMD="$age_key_cmd" sops "$secrets_file" || status=$?

if [[ -f "$secrets_file" ]]; then
  sudo chown "$homelab_user:$homelab_group" "$secrets_file"
  sudo chmod 600 "$secrets_file"
fi

if [[ "$status" -ne 0 && "$status" -ne 200 ]]; then
  exit "$status"
fi
