#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: scripts/set-vaultwarden-signups enable|disable" >&2
  exit 2
fi

case "$1" in
  enable) signups_allowed=true ;;
  disable) signups_allowed=false ;;
  *)
    echo "usage: scripts/set-vaultwarden-signups enable|disable" >&2
    exit 2
    ;;
esac

repo="/srv/ops"
secrets_file="$repo/secrets/homelab.yaml"
age_key_cmd="/run/current-system/sw/bin/ssh-to-age -private-key -i /etc/ssh/ssh_host_ed25519_key"

tmpdir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmpdir"
}
trap cleanup EXIT

plain_json="$tmpdir/plain.json"
updated_json="$tmpdir/updated.json"
encrypted_yaml="$tmpdir/homelab.yaml"

sudo env SOPS_AGE_KEY_CMD="$age_key_cmd" \
  sops --decrypt --output-type json "$secrets_file" > "$plain_json"
chmod 600 "$plain_json"

vaultwarden_env="DOMAIN=https://vault.internal.therealrishabh.com
SIGNUPS_ALLOWED=$signups_allowed
"

jq --arg vaultwarden_env "$vaultwarden_env" \
  '.["vaultwarden.env"] = $vaultwarden_env' \
  "$plain_json" > "$updated_json"
chmod 600 "$updated_json"

(
  cd "$repo"
  sops --encrypt \
    --filename-override secrets/homelab.yaml \
    --input-type json \
    --output-type yaml \
    "$updated_json"
) > "$encrypted_yaml"
chmod 600 "$encrypted_yaml"

mv "$encrypted_yaml" "$secrets_file"
chmod 600 "$secrets_file"

sudo env SOPS_AGE_KEY_CMD="$age_key_cmd" \
  sops --decrypt "$secrets_file" >/dev/null

echo "Vaultwarden SIGNUPS_ALLOWED=$signups_allowed in local encrypted sops secrets." >&2
echo "Run: cd /srv/ops && just switch" >&2
