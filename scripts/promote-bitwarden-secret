#!/usr/bin/env bash
set -euo pipefail
trap 'rc=$?; echo "promote-bitwarden-secret failed near line $LINENO with exit code $rc" >&2' ERR

repo="/srv/ops"
secrets_file="$repo/secrets/homelab.yaml"
age_key_cmd="/run/current-system/sw/bin/ssh-to-age -private-key -i /etc/ssh/ssh_host_ed25519_key"
bw_server_url="${BW_SERVER_URL:-https://vault.internal.therealrishabh.com}"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

confirm() {
  local prompt="$1"
  local answer
  printf "%s [y/N] " "$prompt" >&2
  IFS= read -r answer
  [[ "$answer" == "y" || "$answer" == "Y" || "$answer" == "yes" || "$answer" == "YES" ]]
}

need bw
need fzf
need jq
need sops
need sudo

if [[ ! -t 0 || ! -t 1 ]]; then
  echo "This tool needs an interactive terminal." >&2
  exit 1
fi

if [[ ! -f "$secrets_file" ]]; then
  echo "Missing $secrets_file" >&2
  exit 1
fi

tmpdir="$(mktemp -d)"
chmod 700 "$tmpdir"
cleanup() {
  rm -rf "$tmpdir"
  unset BW_SESSION session selected_value
}
trap cleanup EXIT

status_json="$(bw status --raw 2>/dev/null || printf '{}')"
current_server="$(jq -r '.serverUrl // empty' <<<"$status_json")"

if [[ "$current_server" != "$bw_server_url" ]]; then
  echo "Bitwarden CLI server is: ${current_server:-unset}" >&2
  if confirm "Configure bw to use $bw_server_url?"; then
    bw config server "$bw_server_url" >/dev/null
    status_json="$(bw status --raw 2>/dev/null || printf '{}')"
  fi
fi

session="${BW_SESSION:-}"
status="$(jq -r '.status // "unauthenticated"' <<<"$status_json")"

if [[ "$status" == "unauthenticated" ]]; then
  echo "Log in to Bitwarden/Vaultwarden." >&2
  bw login
  status_json="$(bw status --raw 2>/dev/null || printf '{}')"
  status="$(jq -r '.status // "locked"' <<<"$status_json")"
fi

if [[ -z "$session" && "$status" != "unlocked" ]]; then
  echo "Unlocking Bitwarden/Vaultwarden." >&2
  session="$(bw unlock --raw)"
fi

bw_cmd() {
  if [[ -n "$session" ]]; then
    bw "$@" --session "$session"
  else
    bw "$@"
  fi
}

echo "Syncing Bitwarden metadata..." >&2
bw_cmd sync >/dev/null

items_json="$tmpdir/items.json"
bw_cmd list items > "$items_json"
chmod 600 "$items_json"

item_lines="$tmpdir/items.tsv"
jq -r '
  .[]
  | select(.deletedDate == null)
  | [
      .id,
      (.name // "(unnamed)"),
      (.login.username // ""),
      (.login.uris[0].uri // ""),
      (.type | tostring)
    ]
  | @tsv
' "$items_json" > "$item_lines"

if [[ ! -s "$item_lines" ]]; then
  echo "No Bitwarden items found." >&2
  exit 1
fi

selected_item="$(
  fzf \
    --prompt="Bitwarden item> " \
    --height=80% \
    --border \
    --delimiter=$'\t' \
    --with-nth=2,3,4,5 \
    < "$item_lines" || true
)"

if [[ -z "$selected_item" ]]; then
  echo "No item selected; nothing changed." >&2
  exit 0
fi

item_id="$(cut -f1 <<<"$selected_item")"
item_name="$(cut -f2 <<<"$selected_item")"
item_json="$tmpdir/item.json"
jq --arg id "$item_id" '.[] | select(.id == $id)' "$items_json" > "$item_json"
chmod 600 "$item_json"

fields_tsv="$tmpdir/fields.tsv"
jq -r '
  [
    { key: "login.username", label: "login.username", value: (.login.username // "") },
    { key: "login.password", label: "login.password", value: (.login.password // "") },
    { key: "login.totp", label: "login.totp", value: (.login.totp // "") },
    { key: "sshKey.privateKey", label: "sshKey.privateKey", value: (.sshKey.privateKey // "") },
    { key: "sshKey.publicKey", label: "sshKey.publicKey", value: (.sshKey.publicKey // "") },
    { key: "sshKey.keyFingerprint", label: "sshKey.keyFingerprint", value: (.sshKey.keyFingerprint // .sshKey.fingerprint // "") },
    { key: "notes", label: "notes", value: (.notes // "") }
  ]
  + [
    range(0; ((.fields // []) | length)) as $i
    | (.fields[$i]) as $field
    | {
        key: ("field:" + ($i | tostring)),
        label: ("custom." + ($field.name // ("field-" + ($i | tostring)))),
        value: ($field.value // "")
      }
  ]
  | .[]
  | select((.value | tostring | length) > 0)
  | [.key, .label]
  | @tsv
' "$item_json" > "$fields_tsv"

if [[ ! -s "$fields_tsv" ]]; then
  echo "Selected item has no promotable fields." >&2
  exit 1
fi

selected_field="$(
  fzf \
    --prompt="Field from $item_name> " \
    --height=50% \
    --border \
    --delimiter=$'\t' \
    --with-nth=2 \
    < "$fields_tsv" || true
)"

if [[ -z "$selected_field" ]]; then
  echo "No field selected; nothing changed." >&2
  exit 0
fi

field_key="$(cut -f1 <<<"$selected_field")"
field_label="$(cut -f2 <<<"$selected_field")"
value_file="$tmpdir/value"

case "$field_key" in
  login.username)
    jq -j '.login.username // ""' "$item_json" > "$value_file"
    ;;
  login.password)
    jq -j '.login.password // ""' "$item_json" > "$value_file"
    ;;
  login.totp)
    jq -j '.login.totp // ""' "$item_json" > "$value_file"
    ;;
  sshKey.privateKey)
    jq -j '.sshKey.privateKey // ""' "$item_json" > "$value_file"
    ;;
  sshKey.publicKey)
    jq -j '.sshKey.publicKey // ""' "$item_json" > "$value_file"
    ;;
  sshKey.keyFingerprint)
    jq -j '.sshKey.keyFingerprint // .sshKey.fingerprint // ""' "$item_json" > "$value_file"
    ;;
  notes)
    jq -j '.notes // ""' "$item_json" > "$value_file"
    ;;
  field:*)
    field_index="${field_key#field:}"
    jq -j --argjson i "$field_index" '.fields[$i].value // ""' "$item_json" > "$value_file"
    ;;
  *)
    echo "Unknown field key: $field_key" >&2
    exit 1
    ;;
esac
chmod 600 "$value_file"

if [[ ! -s "$value_file" ]]; then
  echo "Selected field was empty; nothing changed." >&2
  exit 1
fi

echo "Selected: $item_name -> $field_label" >&2
if confirm "Reveal this value in the terminal before promoting it?"; then
  printf "\n----- value start -----\n" >&2
  cat "$value_file"
  printf "\n----- value end -----\n" >&2
  printf "Press Enter to continue..." >&2
  IFS= read -r _
fi

plain_json="$tmpdir/homelab.json"
updated_json="$tmpdir/homelab.updated.json"
encrypted_yaml="$tmpdir/homelab.yaml"

sudo env SOPS_AGE_KEY_CMD="$age_key_cmd" \
  sops --decrypt --output-type json "$secrets_file" > "$plain_json"
chmod 600 "$plain_json"

keys_file="$tmpdir/sops-keys"
{
  echo "<new key>"
  jq -r 'keys[]' "$plain_json"
} > "$keys_file"

selected_sops_key="$(
  fzf \
    --prompt="sops key> " \
    --height=50% \
    --border \
    < "$keys_file" || true
)"

if [[ -z "$selected_sops_key" ]]; then
  echo "No sops key selected; nothing changed." >&2
  exit 0
fi

if [[ "$selected_sops_key" == "<new key>" ]]; then
  printf "New sops key name: " >&2
  IFS= read -r selected_sops_key
fi

if [[ ! "$selected_sops_key" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  echo "Invalid sops key name. Use letters, numbers, dot, underscore, or dash." >&2
  exit 1
fi

if jq -e --arg key "$selected_sops_key" 'has($key)' "$plain_json" >/dev/null; then
  if ! confirm "Overwrite existing sops key '$selected_sops_key'?"; then
    echo "Nothing changed." >&2
    exit 0
  fi
fi

jq \
  --arg key "$selected_sops_key" \
  --rawfile value "$value_file" \
  '.[$key] = $value' \
  "$plain_json" > "$updated_json"
chmod 600 "$updated_json"

(
  cd "$repo"
  sops --encrypt \
    --filename-override secrets/homelab.yaml \
    --input-type json \
    --output-type yaml \
    "$updated_json"
) > "$encrypted_yaml"
chmod 600 "$encrypted_yaml"
mv "$encrypted_yaml" "$secrets_file"
chmod 600 "$secrets_file"

sudo env SOPS_AGE_KEY_CMD="$age_key_cmd" \
  sops --decrypt "$secrets_file" >/dev/null

echo "Promoted '$item_name' field '$field_label' to sops key '$selected_sops_key'." >&2
