#!/usr/bin/env bash
set -euo pipefail

if [[ -r /etc/homelab/paths.env ]]; then
  # shellcheck disable=SC1091
  . /etc/homelab/paths.env
fi

state_root="${CODEX_COMPUTER_USE_STATE:-${homelab_codex_home:-/srv/state/codex}/computer-use}"
desktops_dir="$state_root/desktops"
log_dir="$state_root/log"
default_listen_host="${CODEX_DESKTOP_LISTEN_HOST:-127.0.0.1}"
default_public_host="${CODEX_DESKTOP_PUBLIC_HOST:-$default_listen_host}"
default_vnc_base="${CODEX_DESKTOP_VNC_BASE_PORT:-5900}"
default_web_base="${CODEX_DESKTOP_WEB_BASE_PORT:-6900}"
at_spi_bus_launcher="${CODEX_AT_SPI_BUS_LAUNCHER:-at-spi-bus-launcher}"

usage() {
  cat <<'USAGE'
Usage:
  codex-desktop start [--json] [--id ID] [--profile browser|terminal|blank|none]
                      [--width PX] [--height PX] [--ttl SECONDS]
                      [--listen-host HOST] [--public-host HOST] [-- COMMAND...]
  codex-desktop list [--json]
  codex-desktop status [--json] ID
  codex-desktop env ID
  codex-desktop env-json ID
  codex-desktop exec ID -- COMMAND...
  codex-desktop stop ID
  codex-desktop prune
USAGE
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

need_executable() {
  local command="$1"
  if [[ "$command" == */* ]]; then
    if [[ ! -x "$command" ]]; then
      echo "Missing required executable: $command" >&2
      exit 1
    fi
  else
    need "$command"
  fi
}

ensure_state() {
  mkdir -p "$desktops_dir" "$log_dir"
  chmod 700 "$state_root" "$desktops_dir" "$log_dir"
}

desktop_dir() {
  local id="$1"
  if [[ -z "$id" || "$id" == *"/"* || "$id" == "." || "$id" == ".." ]]; then
    echo "Invalid desktop id: $id" >&2
    exit 1
  fi
  printf '%s/%s\n' "$desktops_dir" "$id"
}

port_is_free() {
  local port="$1"
  ! ss -ltn | awk '{print $4}' | grep -Eq "[:.]${port}$"
}

pid_is_alive() {
  local pid="$1"
  [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" >/dev/null 2>&1
}

quote_env() {
  local key="$1"
  local value="$2"
  printf '%s=%q\n' "$key" "$value"
}

write_manifest() {
  local dir="$1"
  local status="$2"
  local ready="$3"
  local manifest="$dir/manifest.json"
  local expires_at=""

  if (( ttl_seconds > 0 )); then
    expires_at="$(date -Is -d "@$((started_epoch + ttl_seconds))")"
  fi

  jq -n \
    --arg id "$id" \
    --arg status "$status" \
    --arg profile "$profile" \
    --arg dir "$dir" \
    --arg pid "$session_pid" \
    --arg display ":$display_number" \
    --arg listenHost "$listen_host" \
    --arg publicHost "$public_host" \
    --arg startedAt "$started_at" \
    --arg expiresAt "$expires_at" \
    --arg vncUrl "vnc://$public_host:$vnc_port" \
    --arg webUrl "http://$public_host:$web_port/vnc.html?host=$public_host&port=$web_port" \
    --argjson ready "$ready" \
    --argjson width "$width" \
    --argjson height "$height" \
    --argjson ttlSeconds "$ttl_seconds" \
    --argjson displayNumber "$display_number" \
    --argjson vncPort "$vnc_port" \
    --argjson webPort "$web_port" \
    '{
      id: $id,
      status: $status,
      ready: $ready,
      profile: $profile,
      directory: $dir,
      pid: ($pid | tonumber),
      display: $display,
      displayNumber: $displayNumber,
      width: $width,
      height: $height,
      ttlSeconds: $ttlSeconds,
      listenHost: $listenHost,
      publicHost: $publicHost,
      vncPort: $vncPort,
      webPort: $webPort,
      vncUrl: $vncUrl,
      webUrl: $webUrl,
      startedAt: $startedAt,
      expiresAt: $expiresAt
    }' > "$manifest.tmp"
  mv "$manifest.tmp" "$manifest"
}

refresh_manifest() {
  local manifest="$1"
  [[ -f "$manifest" ]] || return 0

  local status pid
  status="$(jq -r '.status // "unknown"' "$manifest")"
  pid="$(jq -r '.pid // empty' "$manifest")"

  if [[ "$status" =~ ^(running|starting)$ ]] && ! pid_is_alive "$pid"; then
    jq --arg stoppedAt "$(date -Is)" \
      '.status = "exited" | .ready = false | .stoppedAt = $stoppedAt' \
      "$manifest" > "$manifest.tmp"
    mv "$manifest.tmp" "$manifest"
  fi
}

run_session() {
  local dir="$1"
  local env_file="$dir/session.env"
  local argv_file="$dir/command.argv"
  local manifest="$dir/manifest.json"

  # shellcheck disable=SC1090
  . "$env_file"

  export HOME="$dir/home"
  export XDG_RUNTIME_DIR="$dir/runtime"
  export DISPLAY=":$display_number"
  export NO_AT_BRIDGE=0
  export AT_SPI_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/at-spi/bus_$display_number"
  export GDK_BACKEND=x11
  export GNOME_ACCESSIBILITY=1
  export GTK_MODULES="${GTK_MODULES:-gail:atk-bridge}"
  export QT_QPA_PLATFORM=xcb
  export XDG_CONFIG_HOME="$dir/config"
  export XDG_CACHE_HOME="$dir/cache"
  export XDG_DATA_HOME="$dir/data"

  mkdir -p "$HOME" "$XDG_RUNTIME_DIR" "$XDG_CONFIG_HOME" "$XDG_CACHE_HOME" "$XDG_DATA_HOME"
  chmod 700 "$XDG_RUNTIME_DIR"

  local pids=()
  cleanup() {
    if [[ -f "$manifest" ]]; then
      jq --arg stoppedAt "$(date -Is)" \
        '.status = "exited" | .ready = false | .stoppedAt = $stoppedAt' \
        "$manifest" > "$manifest.tmp" && mv "$manifest.tmp" "$manifest" || true
    fi
    for child_pid in "${pids[@]:-}"; do
      kill "$child_pid" >/dev/null 2>&1 || true
    done
  }
  trap cleanup EXIT INT TERM

  {
    quote_env DISPLAY "$DISPLAY"
    quote_env XDG_RUNTIME_DIR "$XDG_RUNTIME_DIR"
    quote_env DBUS_SESSION_BUS_ADDRESS "${DBUS_SESSION_BUS_ADDRESS:-}"
    quote_env NO_AT_BRIDGE "$NO_AT_BRIDGE"
    quote_env AT_SPI_BUS_ADDRESS "$AT_SPI_BUS_ADDRESS"
    quote_env GDK_BACKEND "$GDK_BACKEND"
    quote_env GNOME_ACCESSIBILITY "$GNOME_ACCESSIBILITY"
    quote_env GTK_MODULES "$GTK_MODULES"
    quote_env QT_QPA_PLATFORM "$QT_QPA_PLATFORM"
    quote_env HOME "$HOME"
    quote_env XDG_CONFIG_HOME "$XDG_CONFIG_HOME"
    quote_env XDG_CACHE_HOME "$XDG_CACHE_HOME"
    quote_env XDG_DATA_HOME "$XDG_DATA_HOME"
  } > "$dir/env"

  jq -n \
    --arg DISPLAY "$DISPLAY" \
    --arg XDG_RUNTIME_DIR "$XDG_RUNTIME_DIR" \
    --arg DBUS_SESSION_BUS_ADDRESS "${DBUS_SESSION_BUS_ADDRESS:-}" \
    --arg NO_AT_BRIDGE "$NO_AT_BRIDGE" \
    --arg AT_SPI_BUS_ADDRESS "$AT_SPI_BUS_ADDRESS" \
    --arg GDK_BACKEND "$GDK_BACKEND" \
    --arg GNOME_ACCESSIBILITY "$GNOME_ACCESSIBILITY" \
    --arg GTK_MODULES "$GTK_MODULES" \
    --arg QT_QPA_PLATFORM "$QT_QPA_PLATFORM" \
    --arg HOME "$HOME" \
    --arg XDG_CONFIG_HOME "$XDG_CONFIG_HOME" \
    --arg XDG_CACHE_HOME "$XDG_CACHE_HOME" \
    --arg XDG_DATA_HOME "$XDG_DATA_HOME" \
    '{
      DISPLAY: $DISPLAY,
      XDG_RUNTIME_DIR: $XDG_RUNTIME_DIR,
      DBUS_SESSION_BUS_ADDRESS: $DBUS_SESSION_BUS_ADDRESS,
      NO_AT_BRIDGE: $NO_AT_BRIDGE,
      AT_SPI_BUS_ADDRESS: $AT_SPI_BUS_ADDRESS,
      GDK_BACKEND: $GDK_BACKEND,
      GNOME_ACCESSIBILITY: $GNOME_ACCESSIBILITY,
      GTK_MODULES: $GTK_MODULES,
      QT_QPA_PLATFORM: $QT_QPA_PLATFORM,
      HOME: $HOME,
      XDG_CONFIG_HOME: $XDG_CONFIG_HOME,
      XDG_CACHE_HOME: $XDG_CACHE_HOME,
      XDG_DATA_HOME: $XDG_DATA_HOME
    }' > "$dir/env.json"

  Xvfb "$DISPLAY" -screen 0 "${width}x${height}x24" -nolisten tcp -ac +extension RANDR \
    > "$dir/xvfb.log" 2>&1 &
  pids+=("$!")

  local display_ready=0
  for _ in $(seq 1 80); do
    if xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
      display_ready=1
      break
    fi
    sleep 0.25
  done
  if (( display_ready == 0 )); then
    echo "Xvfb did not become ready on $DISPLAY" >&2
    exit 1
  fi

  "$at_spi_bus_launcher" --launch-immediately > "$dir/at-spi.log" 2>&1 &
  pids+=("$!")

  openbox > "$dir/openbox.log" 2>&1 &
  pids+=("$!")

  x11vnc -display "$DISPLAY" -listen "$listen_host" -nopw -forever -shared \
    -rfbport "$vnc_port" -o "$dir/x11vnc.log" > "$dir/x11vnc.stdout.log" 2>&1 &
  pids+=("$!")

  if command -v novnc_proxy >/dev/null 2>&1; then
    novnc_proxy --listen "$listen_host:$web_port" --vnc "$listen_host:$vnc_port" \
      > "$dir/novnc.log" 2>&1 &
    pids+=("$!")
  elif command -v websockify >/dev/null 2>&1; then
    for web_root in /run/current-system/sw/share/novnc /run/current-system/sw/share/noVNC; do
      if [[ -d "$web_root" ]]; then
        websockify --web "$web_root" "$listen_host:$web_port" "$listen_host:$vnc_port" \
          > "$dir/novnc.log" 2>&1 &
        pids+=("$!")
        break
      fi
    done
  fi

  if [[ -s "$argv_file" ]]; then
    local command=()
    mapfile -d '' -t command < "$argv_file"
    "${command[@]}" > "$dir/command.log" 2>&1 &
    pids+=("$!")
  elif [[ "$profile" == "browser" ]]; then
    chromium \
      --user-data-dir="$dir/chromium" \
      --no-first-run \
      --no-default-browser-check \
      --disable-default-apps \
      --disable-dev-shm-usage \
      --disable-gpu \
      --force-renderer-accessibility \
      --ozone-platform=x11 \
      --window-size="${width},${height}" \
      about:blank > "$dir/chromium.log" 2>&1 &
    pids+=("$!")
  elif [[ "$profile" == "terminal" ]]; then
    xterm > "$dir/xterm.log" 2>&1 &
    pids+=("$!")
  elif [[ "$profile" == "blank" || "$profile" == "none" ]]; then
    :
  else
    echo "Unknown desktop profile: $profile" >&2
    exit 1
  fi

  touch "$dir/ready"

  if (( ttl_seconds > 0 )); then
    local deadline=$((started_epoch + ttl_seconds))
    while (( $(date +%s) < deadline )); do
      sleep 5
    done
  else
    while true; do
      sleep 3600
    done
  fi
}

start_desktop() {
  need dbus-run-session
  need jq
  need ss
  need Xvfb
  need xdpyinfo
  need_executable "$at_spi_bus_launcher"
  need openbox
  need x11vnc

  ensure_state

  local output_json=0
  id="codex-$(date +%Y%m%d%H%M%S)-$RANDOM"
  profile="browser"
  width=1440
  height=1000
  ttl_seconds=14400
  listen_host="$default_listen_host"
  public_host="$default_public_host"
  local command=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        output_json=1
        shift
        ;;
      --id)
        id="$2"
        shift 2
        ;;
      --profile)
        profile="$2"
        shift 2
        ;;
      --width)
        width="$2"
        shift 2
        ;;
      --height)
        height="$2"
        shift 2
        ;;
      --ttl)
        ttl_seconds="$2"
        shift 2
        ;;
      --listen-host)
        listen_host="$2"
        shift 2
        ;;
      --public-host)
        public_host="$2"
        shift 2
        ;;
      --)
        shift
        command=("$@")
        break
        ;;
      *)
        echo "Unknown start argument: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done

  if ! [[ "$width" =~ ^[0-9]+$ && "$height" =~ ^[0-9]+$ && "$ttl_seconds" =~ ^[0-9]+$ ]]; then
    echo "width, height, and ttl must be integers" >&2
    exit 2
  fi

  local dir
  dir="$(desktop_dir "$id")"
  if [[ -e "$dir" ]]; then
    echo "Desktop already exists: $id" >&2
    exit 1
  fi

  display_number=""
  vnc_port=""
  web_port=""
  for candidate in $(seq 90 190); do
    local candidate_vnc=$((default_vnc_base + candidate))
    local candidate_web=$((default_web_base + candidate))
    if [[ ! -e "$desktops_dir/.display-$candidate" ]] \
      && port_is_free "$candidate_vnc" \
      && port_is_free "$candidate_web"; then
      display_number="$candidate"
      vnc_port="$candidate_vnc"
      web_port="$candidate_web"
      break
    fi
  done

  if [[ -z "$display_number" ]]; then
    echo "No free display/VNC/noVNC port slot found" >&2
    exit 1
  fi

  mkdir -p "$dir"/{home,runtime,config,cache,data,chromium}
  chmod 700 "$dir" "$dir/runtime"
  : > "$desktops_dir/.display-$display_number"

  started_epoch="$(date +%s)"
  started_at="$(date -Is)"

  {
    quote_env id "$id"
    quote_env profile "$profile"
    quote_env width "$width"
    quote_env height "$height"
    quote_env ttl_seconds "$ttl_seconds"
    quote_env listen_host "$listen_host"
    quote_env public_host "$public_host"
    quote_env display_number "$display_number"
    quote_env vnc_port "$vnc_port"
    quote_env web_port "$web_port"
    quote_env started_epoch "$started_epoch"
  } > "$dir/session.env"

  : > "$dir/command.argv"
  for item in "${command[@]}"; do
    printf '%s\0' "$item" >> "$dir/command.argv"
  done

  setsid dbus-run-session -- "$0" run-session "$dir" > "$dir/session.log" 2>&1 &
  session_pid="$!"

  write_manifest "$dir" "starting" "false"

  local ready=0
  for _ in $(seq 1 80); do
    if [[ -f "$dir/ready" ]]; then
      ready=1
      break
    fi
    if ! pid_is_alive "$session_pid"; then
      refresh_manifest "$dir/manifest.json"
      echo "Desktop session exited before it became ready. See $dir/session.log" >&2
      exit 1
    fi
    sleep 0.25
  done

  if (( ready == 0 )); then
    echo "Desktop session did not become ready. See $dir/session.log" >&2
    exit 1
  fi

  write_manifest "$dir" "running" "true"

  if (( output_json )); then
    cat "$dir/manifest.json"
  else
    jq -r '"Started \(.id) on DISPLAY=\(.display); noVNC=\(.webUrl); VNC=\(.vncUrl)"' "$dir/manifest.json"
  fi
}

list_desktops() {
  ensure_state

  local output_json=0
  if [[ "${1:-}" == "--json" ]]; then
    output_json=1
  fi

  local files=()
  while IFS= read -r -d '' manifest; do
    refresh_manifest "$manifest"
    files+=("$manifest")
  done < <(find "$desktops_dir" -mindepth 2 -maxdepth 2 -name manifest.json -print0 | sort -z)

  if (( ${#files[@]} == 0 )); then
    if (( output_json )); then
      printf '[]\n'
    fi
    return 0
  fi

  if (( output_json )); then
    jq -s '.' "${files[@]}"
  else
    jq -r '. | [.id, .status, .display, .webUrl] | @tsv' "${files[@]}"
  fi
}

status_desktop() {
  ensure_state

  local output_json=0
  if [[ "${1:-}" == "--json" ]]; then
    output_json=1
    shift
  fi
  local id_arg="${1:-}"
  local dir
  dir="$(desktop_dir "$id_arg")"
  local manifest="$dir/manifest.json"
  if [[ ! -f "$manifest" ]]; then
    echo "Unknown desktop: $id_arg" >&2
    exit 1
  fi
  refresh_manifest "$manifest"
  if (( output_json )); then
    cat "$manifest"
  else
    jq -r '. | [.id, .status, .display, .webUrl] | @tsv' "$manifest"
  fi
}

env_desktop() {
  ensure_state
  local id_arg="$1"
  local dir
  dir="$(desktop_dir "$id_arg")"
  if [[ ! -f "$dir/env" ]]; then
    echo "Desktop environment is not ready: $id_arg" >&2
    exit 1
  fi
  cat "$dir/env"
}

env_json_desktop() {
  ensure_state
  local id_arg="$1"
  local dir
  dir="$(desktop_dir "$id_arg")"
  if [[ ! -f "$dir/env.json" ]]; then
    echo "Desktop environment is not ready: $id_arg" >&2
    exit 1
  fi
  cat "$dir/env.json"
}

exec_desktop() {
  ensure_state
  local id_arg="$1"
  shift
  if [[ "${1:-}" != "--" ]]; then
    echo "exec requires -- before the command" >&2
    exit 2
  fi
  shift
  if [[ $# -eq 0 ]]; then
    echo "exec requires a command" >&2
    exit 2
  fi
  local dir
  dir="$(desktop_dir "$id_arg")"
  if [[ ! -f "$dir/env" ]]; then
    echo "Desktop environment is not ready: $id_arg" >&2
    exit 1
  fi
  set -a
  # shellcheck disable=SC1090,SC1091
  . "$dir/env"
  set +a
  cd "$dir"
  exec "$@"
}

stop_desktop() {
  ensure_state
  need jq
  local id_arg="$1"
  local dir
  dir="$(desktop_dir "$id_arg")"
  local manifest="$dir/manifest.json"
  if [[ ! -f "$manifest" ]]; then
    echo "Unknown desktop: $id_arg" >&2
    exit 1
  fi

  local pid display
  pid="$(jq -r '.pid // empty' "$manifest")"
  display="$(jq -r '.displayNumber // empty' "$manifest")"
  if pid_is_alive "$pid"; then
    kill -TERM "-$pid" >/dev/null 2>&1 || kill -TERM "$pid" >/dev/null 2>&1 || true
    sleep 1
    if pid_is_alive "$pid"; then
      kill -KILL "-$pid" >/dev/null 2>&1 || kill -KILL "$pid" >/dev/null 2>&1 || true
    fi
  fi

  jq --arg stoppedAt "$(date -Is)" \
    '.status = "stopped" | .ready = false | .stoppedAt = $stoppedAt' \
    "$manifest" > "$manifest.tmp"
  mv "$manifest.tmp" "$manifest"

  if [[ -n "$display" ]]; then
    rm -f "$desktops_dir/.display-$display"
  fi

  jq -r '"Stopped \(.id)"' "$manifest"
}

prune_desktops() {
  ensure_state
  while IFS= read -r -d '' manifest; do
    refresh_manifest "$manifest"
    local status dir
    status="$(jq -r '.status // empty' "$manifest")"
    dir="$(dirname "$manifest")"
    if [[ "$status" =~ ^(stopped|exited)$ ]]; then
      local display
      display="$(jq -r '.displayNumber // empty' "$manifest")"
      if [[ -n "$display" ]]; then
        rm -f "$desktops_dir/.display-$display"
      fi
      rm -rf "$dir"
    fi
  done < <(find "$desktops_dir" -mindepth 2 -maxdepth 2 -name manifest.json -print0)
}

main() {
  local subcommand="${1:-}"
  shift || true

  case "$subcommand" in
    start)
      start_desktop "$@"
      ;;
    list)
      list_desktops "$@"
      ;;
    status)
      status_desktop "$@"
      ;;
    env)
      env_desktop "$@"
      ;;
    env-json)
      env_json_desktop "$@"
      ;;
    exec)
      exec_desktop "$@"
      ;;
    stop)
      stop_desktop "$@"
      ;;
    prune)
      prune_desktops "$@"
      ;;
    run-session)
      run_session "$@"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "Unknown command: $subcommand" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
